<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Arsenal Business Corporation</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-950 text-white font-sans">

  <!-- Header -->
  <header class="flex flex-col md:flex-row justify-between items-center p-6 border-b border-gray-800 gap-4">
    <h1 class="text-2xl font-bold tracking-wide">Arsenal Business Corporation</h1>
    <nav class="space-x-6 text-sm">
      <a href="#services" class="hover:text-gray-400">Services</a>
      <a href="#about" class="hover:text-gray-400">About</a>
      <a href="#contact" class="hover:text-gray-400">Contact</a>
    </nav>
  </header>

  <!-- Hero -->
  <section class="text-center py-24 px-6">
    <h2 class="text-4xl md:text-5xl font-bold mb-6">Elevate Your Brand</h2>
    <p class="text-gray-400 max-w-2xl mx-auto mb-8">
      Full-service marketing solutions designed to grow your business, increase visibility, and deliver measurable results.
    </p>
    <a href="#contact" class="bg-white text-black px-6 py-3 rounded-full font-semibold hover:bg-gray-200">
      Get Started
    </a>
  </section>

  <!-- Services -->
  <section id="services" class="py-20 px-6 bg-gray-900">
    <h3 class="text-3xl font-semibold text-center mb-12">Our Services</h3>

    <div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">
      <div class="p-6 bg-gray-800 rounded-2xl">
        <h4 class="text-xl font-semibold mb-2">Digital Marketing</h4>
        <p class="text-gray-400">SEO, social media marketing, and paid campaigns to grow your online presence.</p>
      </div>

      <div class="p-6 bg-gray-800 rounded-2xl">
        <h4 class="text-xl font-semibold mb-2">Branding & Design</h4>
        <p class="text-gray-400">Logos, promotional materials, and complete brand identity development.</p>
      </div>

      <div class="p-6 bg-gray-800 rounded-2xl">
        <h4 class="text-xl font-semibold mb-2">Web Design</h4>
        <p class="text-gray-400">Modern, responsive websites built to convert visitors into clients.</p>
      </div>

      <div class="p-6 bg-gray-800 rounded-2xl">
        <h4 class="text-xl font-semibold mb-2">Direct Mail Marketing</h4>
        <p class="text-gray-400">Targeted campaigns designed to reach the right audience effectively.</p>
      </div>

      <div class="p-6 bg-gray-800 rounded-2xl">
        <h4 class="text-xl font-semibold mb-2">Advertising Strategy</h4>
        <p class="text-gray-400">Data-driven advertising designed to maximize ROI and brand awareness.</p>
      </div>

      <div class="p-6 bg-gray-800 rounded-2xl">
        <h4 class="text-xl font-semibold mb-2">Social Media Management</h4>
        <p class="text-gray-400">Content creation, posting, and growth strategies across all platforms.</p>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-20 px-6 text-center">
    <h3 class="text-3xl font-semibold mb-6">About Us</h3>
    <p class="text-gray-400 max-w-3xl mx-auto">
      Arsenal Business Corporation is a full-service marketing agency helping businesses grow through strategy, design, and digital execution. We focus on building strong brands that stand out and scale.
    </p>
  </section>

  <!-- Contact -->
  <section id="contact" class="py-20 px-6 bg-gray-900 text-center">
    <h3 class="text-3xl font-semibold mb-6">Contact Us</h3>

    <p class="text-gray-400 mb-2">1369 Glassboro Rd, Woodbury Heights, NJ 08097</p>
    <p class="text-gray-400 mb-2">Open 24 Hours</p>
    <p class="text-gray-400 mb-6">(856) 219-2226</p>

    <a href="tel:+18562192226" class="bg-white text-black px-6 py-3 rounded-full font-semibold hover:bg-gray-200">
      Call Now
    </a>
  </section>

  <!-- Footer -->
  <footer class="text-center p-6 border-t border-gray-800 text-gray-500 text-sm">
    © 2026 Arsenal Business Corporation. All rights reserved.
  </footer>

</body>
</html>
